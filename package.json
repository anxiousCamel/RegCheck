{
  "name": "regcheck",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=@regcheck/api --filter=@regcheck/web --output-logs=full --ui=stream",
    "dev:api": "turbo dev --filter=@regcheck/api --output-logs=full --ui=stream",
    "dev:web": "turbo dev --filter=@regcheck/web --output-logs=full --ui=stream",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean",
    "infra:up": "node scripts/docker.mjs compose -f infra/docker-compose.yml up -d --remove-orphans",
    "infra:down": "node scripts/docker.mjs compose -f infra/docker-compose.yml down",
    "infra:logs": "node scripts/docker.mjs compose -f infra/docker-compose.yml up --remove-orphans",
    "wait:infra": "pnpm exec wait-on tcp:localhost:5432 tcp:localhost:6379",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:studio": "pnpm --filter @regcheck/database db:studio",
    "db:export": "node scripts/db-export.mjs",
    "db:import": "node scripts/db-import.mjs",
    "db:restore": "node scripts/db-import.mjs backups/backup-2026-03-28T14-12-28.zip",
    "db:restore-pdfs": "node scripts/restore-pdfs-only.mjs backups/backup-2026-03-28T14-12-28.zip",
    "setup:env": "node scripts/setup-env.mjs",
    "seed:balanças": "node scripts/seed-balanças.mjs",
    "generate:docs": "tsx scripts/generate-docs.ts",
    "up": "pnpm infra:up && pnpm wait:infra && pnpm setup:env && pnpm dev",
    "up:studio": "pnpm infra:up && pnpm exec concurrently -k -n APPS,STUDIO -c auto \"pnpm wait:infra && pnpm setup:env && pnpm dev\" \"pnpm wait:infra && pnpm db:studio\"",
    "start:fresh": "node -e \"require('os').platform()==='win32' ? require('child_process').execSync('powershell -ExecutionPolicy Bypass -File scripts/start-fresh.ps1', {stdio:'inherit'}) : require('child_process').execSync('bash scripts/start-fresh.sh', {stdio:'inherit'})\"",
    "start:restore": "node scripts/start-with-restore.mjs",
    "reinstall": "node -e \"require('os').platform()==='win32' ? require('child_process').execSync('powershell -ExecutionPolicy Bypass -File scripts/reinstall.ps1', {stdio:'inherit'}) : require('child_process').execSync('bash scripts/reinstall.sh', {stdio:'inherit'})\""
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.7.0",
    "turbo": "^2.9.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.4"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
